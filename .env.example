# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# --- Discord ---
DISCORD_TOKEN=
DISCORD_USER_ID=

# --- LLM (any OpenAI-compatible chat endpoint: DeepSeek, a Claude-compatible gateway, ...) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash   # deepseek-chat/-reasoner are deprecated 2026-07-24

# --- Optional overrides (defaults shown) ---
# BOT_NAME=Bot
# TIMEZONE=Europe/London
# MESSAGE_LANG=zh        # language of the bot's DMs (zh / en)
# DIALOGUE_HISTORY=12    # recent DMs fed as context when writing a message (higher = more memory, more tokens)
