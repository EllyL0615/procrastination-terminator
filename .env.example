# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# --- Discord ---
DISCORD_TOKEN=
DISCORD_USER_ID=
DISCORD_CHANNEL_ID=   # the text channel the bot posts in and listens on (enable Developer Mode, right-click the channel -> Copy Channel ID)

# --- LLM (any OpenAI-compatible chat endpoint: DeepSeek, a Claude-compatible gateway, ...) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash   # deepseek-chat/-reasoner are deprecated 2026-07-24

# --- Optional overrides (defaults shown) ---
# BOT_NAME=Bot
# TIMEZONE=Europe/London
# MESSAGE_LANG=en        # language of the bot's messages (zh / en)
# DIALOGUE_HISTORY=12    # recent messages fed as context when writing a message (higher = more memory, more tokens)

# --- Storage backend (file = local files under data/, default; notion = Notion) ---
# STORAGE_BACKEND=file
# NOTION_API_KEY=            # required when STORAGE_BACKEND=notion (Notion internal integration secret)
# NOTION_DB_ID=             # the tasks database id (share the database with your integration)
# NOTION_PLAN_PAGE_ID=      # page whose text blocks are your free-form plan
# NOTION_CONTEXT_PAGE_ID=   # page whose text blocks are your standing context (glossary / tone)
